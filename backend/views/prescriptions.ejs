<!DOCTYPE html>
<title>Medagascar</title>
<head>
    <script src="https://kit.fontawesome.com/b99e675b6e.js"></script>
    <link rel="stylesheet" href="css/styles.css">
    
</head>
<body>
    
    <div class="clearfix">
        <div class="wrapper">
            <div class="sidebar">
                <div class = "logo"><h2>Medagascar</h2></div>
                <br><br><br>
                <ul>
                    <li><a href="/profile"><i class="fas fa-user"></i>Profile</a></li>
                    <li><a href="/upload"><i class="fas fa-upload"></i>Upload</a></li>
                    <li><a href="/prescription"><i class="fas fa-prescription"></i>Prescription</a></li>
                    <li><a href="/logout"><i class="fas fa-sign-out-alt"></i>Sign Out</a></li>
                    
                </ul> 
                </div>
            </div>
        </div>
        <div class="pres-upload">
            <ul>
              
                <!-- <img id="image"
                    src="https://images.unsplash.com/photo-1675710640218-d5329c2fdba4?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxleHBsb3JlLWZlZWR8Mnx8fGVufDB8fHx8"
                    height="100" width="100"> -->

                <div class="container">
                    <div class="row">
                        <%if (records.length>0){ %>
                            <% records.forEach(function(row){ %>
                                <div class="col-md-4">
                                    <img src="/<%= row.imageDetails %>" alt="image" style="width:100px;margin:5px auto;">
                                </div>
                                <% }) }%>
                    </div>
                </div>
             
            </ul>
            
        </div>
    </div>

    <script>
        function show() {
                var x = document.getElementById("image");
                if (x.style.display === "none") {
                    x.style.display = "block";
                    console.log("entered show()")
                } else {
                    x.style.display = "none";
                }
            }
    </script>
</body>
</html>
